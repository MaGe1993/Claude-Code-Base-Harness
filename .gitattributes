# Normalize line endings across platforms.
# The harness ships both .ps1 (Windows) and .sh (Unix) hooks; the .sh and .mjs
# files MUST stay LF or they break on macOS/Linux regardless of the user's
# core.autocrlf setting.
* text=auto eol=lf

*.sh   text eol=lf
*.mjs  text eol=lf
*.bash text eol=lf
*.ps1  text eol=crlf
*.bat  text eol=crlf

# Binary assets — never normalize
*.png binary
*.jpg binary
*.gif binary
*.ico binary
